#!/bin/bash
# Blocks commits if email not in allowed list
# Works on ANY machine - no external dependencies

EMAIL=$(git config user.email)
ALLOWED=("github.relock416@passmail.net" "me@vd7.io")

for a in "${ALLOWED[@]}"; do
    [[ "$EMAIL" == "$a" ]] && exit 0
done

echo ""
echo "❌ BLOCKED: $EMAIL not allowed"
echo ""
echo "Fix: git config user.email 'github.relock416@passmail.net'"
echo " or: git config user.email 'me@vd7.io'"
echo ""
exit 1
